# Server
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5500
CORS_ORIGIN=http://localhost:5500

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/bakal_gym

# PayMongo
# IMPORTANT: use test key first. Never put this in frontend JavaScript.
PAYMONGO_SECRET_KEY=sk_test_your_new_key_here
PAYMONGO_WEBHOOK_SECRET=whsec_your_webhook_secret_here
PAYMONGO_MODE=test
PAYMONGO_PAYMENT_METHODS=gcash,card

# Admin panel basic login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# OpenAI (for AI Fitness Suggestion)
OPENAI_API_KEY=sk-your_openai_key_here
